{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Chess Project",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",

                "-I",
                "${workspaceFolder}/include",

                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/Board.cpp",
                "${workspaceFolder}/src/Piece.cpp",
                "${workspaceFolder}/src/Position.cpp",
                "${workspaceFolder}/src/Pawn.cpp",
                "${workspaceFolder}/src/Rook.cpp",
                "${workspaceFolder}/src/Knight.cpp",
                "${workspaceFolder}/src/Bishop.cpp",
                "${workspaceFolder}/src/Queen.cpp",
                "${workspaceFolder}/src/King.cpp",
                "${workspaceFolder}/src/Move.cpp",
                "${workspaceFolder}/src/Game.cpp",
                "${workspaceFolder}/src/Renderer.cpp",

                "-o",
                "${workspaceFolder}/chess.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}